{
  "name": "treasures",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm i && vite",
    "build": "npm i && vite build && cp dist/index.html dist/404.html",
    "test": "npm i && tsc -p tsconfig.app.json --noEmit && eslint && vitest run && vite build",
    "deploy": "test -n \"$DROPLET_IP\" && ./deploy.sh $DROPLET_IP || echo 'Set DROPLET_IP environment variable'",
    "deploy:nostr": "npm run build && npx -y nostr-deploy-cli deploy --skip-setup",
    "deploy:debug": "test -n \"$DROPLET_IP\" && ./deploy.sh $DROPLET_IP --debug || echo 'Set DROPLET_IP environment variable'",
    "deploy:docker": "test -n \"$DROPLET_IP\" && ./docker/deploy.sh $DROPLET_IP || echo 'Set DROPLET_IP environment variable (legacy Docker method)'",
    "docker:build": "docker build -t treasures-app -f docker/Dockerfile .",
    "docker:run": "./docker/test-docker.sh",
    "docker:test": "./docker/test-docker.sh --rebuild",
    "docker:stop": "./docker/test-docker.sh --stop",
    "generate-icons": "node scripts/generate-icons.js",
    "process-icon": "node scripts/process-icon.js",
    "create-og-image": "node scripts/create-og-image.js"
  },
